PYTHON = ./.venv/bin/python

generate-rootca:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py generate-rootca

install-rootca-windows:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install-rootca-windows

setup-vault:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py setup-vault-base

setup-cron:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py setup_cron

setup-host-network: ## [Dev] Configure /etc/hosts and Trust Root CA (sudo required)
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py setup-host-network

install-postgres:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install postgres

install-postgres--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install postgres --reset

test-core: ## Verify Core Services (Postgres, LDAP, etc.) from tests/core
	@echo "Running Core Infrastructure Functional Tests..."
	@$(PYTHON) -m pytest -v --html=tests/report.html --self-contained-html tests/core/

backup-postgres:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py backup postgres

restore-postgres:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py restore postgres

install-nginx:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install nginx

install-nginx--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install nginx --reset

verify-nginx-security: ## Verify WAF and Immutable FS
	$(PYTHON) scripts/ai4radmed/verify_nginx_security.py

install-vaultwarden:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install vaultwarden

install-vaultwarden--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install vaultwarden --reset

install-ldap:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install ldap

install-ldap--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install ldap --reset

install-elk:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install elk

install-elk--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install elk --reset

install-vault:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install vault

install-vault--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install vault --reset

init-vault:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py init-vault

unseal-vault:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py unseal-vault

check-vault: ## Check Vault Status (Sealed/Unsealed)
	@docker exec ai4radmed-vault vault status -address=https://127.0.0.1:8200 -tls-skip-verify || echo "Vault is Sealed or Down"

backup-vault:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py backup vault

restore-vault:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py restore vault

install-keycloak:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install keycloak

install-keycloak--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install keycloak --reset

setup-keycloak: ## Configure Realm/LDAP/Clients
	$(PYTHON) scripts/ai4radmed/keycloak_setup.py

seed-users: ## Seed initial users into LDAP
	$(PYTHON) scripts/ai4radmed/seed_users.py

install-orthanc-mock:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-mock

install-orthanc-mock--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-mock --reset

install-pacs-stack:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-mock
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-raw
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-pseudo

install-pacs-stack--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-mock --reset
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-raw --reset
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install orthanc-pseudo --reset

install-dcmtk:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install dcmtk

install-dcmtk--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install dcmtk --reset

install-slicer:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install slicer

install-slicer--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install slicer --reset



install-all:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install all

install-all--reset:
	$(PYTHON) scripts/ai4radmed/ai4radmed-cli.py install all --reset

# --- Testing ---
test: ## Run automated tests and generate report
	@./.venv/bin/python scripts/ai4radmed/test_runner.py

test-integration: ## Run PACS integration tests using DCMTK
	@./.venv/bin/python -m pytest tests/integration/test_pacs_workflow.py

test-security: ## Run security implementation verification tests
	@./.venv/bin/python -m pytest tests/security/
